# Copy to .env and fill in values

# --- LLM Provider ---
# "anthropic" | "openai" | "vllm"
# DIALOGVIS_PROVIDER=anthropic

# # Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# DIALOGVIS_MODEL=claude-sonnet-4-6

# OpenAI / vLLM (override model and base URL)
# OPENAI_API_KEY=sk-...
# DIALOGVIS_MODEL=gpt-4o
# DIALOGVIS_API_BASE_URL=https://api.openai.com/v1

#For local vLLM: 
DIALOGVIS_PROVIDER=vllm
DIALOGVIS_MODEL=Qwen/Qwen2-VL-7B-Instruct
DIALOGVIS_API_BASE_URL=http://localhost:8000/v1
DIALOGVIS_API_KEY=EMPTY

# --- Generation ---
DIALOGVIS_TEMPERATURE=0.8
DIALOGVIS_MAX_TOKENS=4096
DIALOGVIS_CONCURRENCY=4
DIALOGVIS_MAX_RETRIES=3
